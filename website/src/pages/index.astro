---
import Layout from '../layouts/Layout.astro';

const repoUrl = 'https://github.com/huaruic/clawsetup';

const highlights = [
  {
    title: 'Beginner-first setup',
    body: 'Turn OpenClaw setup into a guided visual flow instead of a fragile sequence of terminal commands.',
  },
  {
    title: 'Local-first by design',
    body: 'Keep runtime, config, and control on your own machine with a workflow built for local usage.',
  },
  {
    title: 'Fast confidence checks',
    body: 'See install status, runtime readiness, and next actions in one place instead of guessing.',
  },
  {
    title: 'Built for real onboarding',
    body: 'Ideal for first-time OpenClaw users, demos, workshops, and non-technical teammates.',
  },
];

const steps = [
  'Check the local environment and OpenClaw CLI state.',
  'Configure your provider in a visual setup flow.',
  'Launch OpenClaw locally and verify runtime readiness.',
  'Finish setup and continue from a lightweight dashboard.',
];

const gallery = [
  {
    title: 'Welcome screen',
    description: 'A clear first step with environment context and an approachable setup entry point.',
    src: '/readme/01-welcome.png',
    alt: 'ClawSetup welcome screen showing the first step of the local setup flow.',
  },
  {
    title: 'Provider configuration',
    description: 'Paste credentials, validate configuration, and move forward without editing local files by hand.',
    src: '/readme/03-ai-provider.png',
    alt: 'ClawSetup provider setup screen with visual configuration form.',
  },
  {
    title: 'Runtime ready',
    description: 'Know when OpenClaw is actually running and inspect the state without switching back to terminal logs.',
    src: '/readme/05-onboarding-ready.png',
    alt: 'ClawSetup runtime ready screen confirming local OpenClaw is available.',
  },
  {
    title: 'Setup complete',
    description: 'Finish with a direct path into the OpenClaw dashboard and a clearer sense of what is ready.',
    src: '/readme/10-setup-complete.png',
    alt: 'ClawSetup completion screen after the guided setup finishes.',
  },
];

const faqs = [
  {
    question: 'Is ClawSetup a cloud service?',
    answer: 'No. The product direction is local-first and privacy-first. The setup flow is designed around running OpenClaw on your own machine.',
  },
  {
    question: 'Do I need to use terminal commands?',
    answer: 'That is exactly the friction ClawSetup tries to remove. The goal is to make setup approachable through a guided interface.',
  },
  {
    question: 'Who is this for?',
    answer: 'It is built for OpenClaw beginners, workshop participants, and anyone who prefers a visual setup experience over manual local configuration.',
  },
  {
    question: 'What does V1 of the website focus on?',
    answer: 'A concise product story, screenshot walkthrough, local-first positioning, and a clear GitHub CTA.',
  },
];
---

<Layout>
  <main class="page-shell">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>

    <header class="topbar">
      <a class="brand" href="#top" aria-label="ClawSetup home">
        <span class="brand-mark">
          <img src="/logo.svg" alt="ClawSetup" width="28" height="28" />
        </span>
        <span class="brand-copy">
          <strong>ClawSetup</strong>
          <small>OpenClaw local desktop client</small>
        </span>
      </a>

      <nav class="nav">
        <a href="#why">Why</a>
        <a href="#walkthrough">Walkthrough</a>
        <a href="#faq">FAQ</a>
        <a class="nav-cta" href={repoUrl} target="_blank" rel="noreferrer">GitHub</a>
      </nav>
    </header>

    <section class="hero" id="top">
      <div class="hero-copy">
        <div class="eyebrow">
          <span>macOS</span>
          <span>Local-first</span>
          <span>No terminal required</span>
        </div>

        <h1>Run OpenClaw locally without terminal friction.</h1>
        <p class="hero-text">
          ClawSetup is a beginner-friendly desktop client for installing, configuring, and
          verifying OpenClaw through a fast visual flow built for first-time users.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href={repoUrl} target="_blank" rel="noreferrer">
            Star on GitHub
          </a>
          <a class="button button-secondary" href="#walkthrough">View walkthrough</a>
        </div>

        <ul class="hero-points">
          <li>Visual onboarding instead of command-line guesswork</li>
          <li>Runtime visibility, logs, and confidence checks in one place</li>
          <li>Designed for beginners, demos, and workshop-friendly setup</li>
        </ul>
      </div>

      <div class="hero-visual">
        <div class="hero-panel">
          <div class="panel-bar">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <img
            src="/readme/01-welcome.png"
            alt="ClawSetup landing hero showing the welcome step of the setup wizard."
            width="1600"
            height="1038"
          />
        </div>
        <div class="stat-card stat-a">
          <strong>1 minute goal</strong>
          <span>Designed to reduce first-run setup friction.</span>
        </div>
        <div class="stat-card stat-b">
          <strong>Local control</strong>
          <span>Built around private, on-device OpenClaw usage.</span>
        </div>
      </div>
    </section>

    <section class="section-grid" id="why">
      <div class="section-intro">
        <span class="section-kicker">Why ClawSetup</span>
        <h2>OpenClaw is powerful. The first-run experience still scares off too many users.</h2>
        <p>
          The product opportunity is not just a nicer UI. It is a simpler, more confidence-building
          path for people who want local AI tooling without translating docs into shell commands.
        </p>
      </div>

      <div class="card-grid">
        {highlights.map((item) => (
          <article class="info-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-grid">
      <div class="section-intro narrow">
        <span class="section-kicker">What happens</span>
        <h2>A setup flow that feels more like onboarding than troubleshooting.</h2>
      </div>

      <ol class="flow-list">
        {steps.map((step, index) => (
          <li class="flow-item">
            <span class="flow-index">0{index + 1}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="section-grid" id="walkthrough">
      <div class="section-intro">
        <span class="section-kicker">Walkthrough</span>
        <h2>Show the product, not just the promise.</h2>
        <p>
          The first website version reuses the actual product screens so visitors can understand the
          flow before they ever clone the repository.
        </p>
      </div>

      <div class="gallery">
        {gallery.map((item) => (
          <figure class="gallery-card">
            <img src={item.src} alt={item.alt} width="1600" height="1038" loading="lazy" />
            <figcaption>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="story-panel">
      <div>
        <span class="section-kicker">Why local-first matters</span>
        <h2>ClawSetup is the entry point to a privacy-first OpenClaw desktop experience.</h2>
      </div>
      <p>
        This is not just a wrapper around install commands. It is the foundation of a more
        approachable OpenClaw client: local control, clearer status, and a setup experience that
        helps users trust what is happening.
      </p>
    </section>

    <section class="faq-section" id="faq">
      <div class="section-intro narrow">
        <span class="section-kicker">FAQ</span>
        <h2>Short answers for the first questions visitors will ask.</h2>
      </div>

      <div class="faq-list">
        {faqs.map((item) => (
          <article class="faq-item">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cta-panel">
      <div>
        <span class="section-kicker">Get started</span>
        <h2>Explore the repo, follow the product story, and try the local flow.</h2>
      </div>

      <div class="cta-actions">
        <a class="button button-primary" href={repoUrl} target="_blank" rel="noreferrer">
          Open GitHub
        </a>
        <a class="button button-secondary" href={`${repoUrl}#quick-start`} target="_blank" rel="noreferrer">
          Quick start
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-shell {
    position: relative;
    overflow: clip;
    padding: 24px;
  }

  .ambient {
    position: absolute;
    border-radius: 999px;
    filter: blur(40px);
    pointer-events: none;
  }

  .ambient-a {
    top: 100px;
    right: -120px;
    width: 320px;
    height: 320px;
    background: rgba(232, 93, 76, 0.14);
  }

  .ambient-b {
    top: 720px;
    left: -100px;
    width: 280px;
    height: 280px;
    background: rgba(255, 176, 136, 0.1);
  }

  .topbar,
  .hero,
  .section-grid,
  .story-panel,
  .faq-section,
  .cta-panel {
    position: relative;
    z-index: 1;
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
    padding: 8px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line-strong);
    border-radius: 14px;
    background: rgba(20, 10, 8, 0.6);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .brand-mark img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand-copy strong {
    font-size: 1rem;
    letter-spacing: 0.03em;
  }

  .brand-copy small {
    color: var(--muted);
    font-size: 0.78rem;
  }

  .nav {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  .nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .nav-cta {
    padding: 10px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    color: var(--text) !important;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(420px, 0.96fr);
    gap: 40px;
    align-items: center;
    padding: 18px 0 72px;
  }

  .eyebrow,
  .section-kicker {
    display: inline-flex;
    gap: 10px;
    flex-wrap: wrap;
    color: var(--accent-strong);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
  }

  .eyebrow span {
    padding: 8px 12px;
    border: 1px solid rgba(255, 176, 136, 0.18);
    border-radius: 999px;
    background: rgba(255, 176, 136, 0.06);
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  h1 {
    margin-top: 22px;
    font-size: clamp(3rem, 7vw, 5.8rem);
    line-height: 0.95;
    max-width: 11ch;
  }

  .hero-text,
  .section-intro p,
  .story-panel p,
  .faq-item p,
  .gallery-card p,
  .info-card p,
  .flow-item p {
    color: var(--muted);
    font-size: 1.04rem;
  }

  .hero-text {
    max-width: 58ch;
    margin: 22px 0 0;
  }

  .hero-actions,
  .cta-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: linear-gradient(135deg, #e85d4c 0%, #ffb088 100%);
    color: #140a08;
  }

  .button-secondary {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.03);
    color: var(--text);
  }

  .hero-points {
    display: grid;
    gap: 10px;
    margin: 26px 0 0;
    padding: 0;
    list-style: none;
    color: var(--text);
  }

  .hero-points li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .hero-points li::before {
    content: '';
    width: 10px;
    height: 10px;
    margin-top: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #e85d4c 0%, #ffb088 100%);
    flex: 0 0 auto;
  }

  .hero-visual {
    position: relative;
    padding-bottom: 52px;
  }

  .hero-panel,
  .info-card,
  .flow-item,
  .gallery-card,
  .story-panel,
  .faq-item,
  .cta-panel {
    border: 1px solid var(--line);
    background: linear-gradient(180deg, var(--panel-strong), var(--panel));
    box-shadow: var(--shadow);
  }

  .hero-panel {
    overflow: hidden;
    border-radius: 28px;
  }

  .panel-bar {
    display: flex;
    gap: 8px;
    padding: 16px 18px;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
  }

  .panel-bar span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 160, 120, 0.3);
  }

  .hero-panel img {
    width: 100%;
    height: auto;
  }

  .stat-card {
    position: absolute;
    max-width: 220px;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 20px;
    background: rgba(20, 10, 8, 0.9);
    backdrop-filter: blur(16px);
  }

  .stat-card strong,
  .gallery-card strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 6px;
  }

  .stat-card span {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .stat-a {
    left: -28px;
    bottom: 18px;
  }

  .stat-b {
    right: -18px;
    top: 34px;
  }

  .section-grid,
  .faq-section {
    padding: 36px 0 26px;
  }

  .section-intro {
    display: grid;
    gap: 16px;
    max-width: 780px;
    margin-bottom: 26px;
  }

  .section-intro h2,
  .story-panel h2,
  .cta-panel h2 {
    font-size: clamp(2rem, 4.8vw, 3.5rem);
    line-height: 1.02;
  }

  .narrow {
    max-width: 680px;
  }

  .card-grid,
  .gallery,
  .faq-list {
    display: grid;
    gap: 18px;
  }

  .card-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .info-card {
    border-radius: 24px;
    padding: 24px;
  }

  .info-card h3 {
    margin-bottom: 10px;
    font-size: 1.35rem;
  }

  .flow-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .flow-item {
    border-radius: 24px;
    padding: 22px;
  }

  .flow-index {
    display: inline-flex;
    margin-bottom: 18px;
    color: var(--accent-strong);
    font-size: 0.88rem;
    letter-spacing: 0.12em;
  }

  .gallery {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gallery-card {
    margin: 0;
    overflow: hidden;
    border-radius: 26px;
  }

  .gallery-card img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    vertical-align: top;
  }

  .gallery-card figcaption {
    padding: 18px 18px 20px;
  }

  .gallery-card p {
    margin: 0;
  }

  .story-panel,
  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: 24px;
    align-items: start;
    margin-top: 38px;
    padding: 30px;
    border-radius: 30px;
  }

  .faq-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .faq-item {
    border-radius: 24px;
    padding: 22px 24px;
  }

  .faq-item h3 {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  .faq-item p {
    margin: 14px 0 0;
  }

  .cta-panel {
    margin-top: 26px;
    margin-bottom: 36px;
  }

  @media (max-width: 1100px) {
    .hero,
    .story-panel,
    .cta-panel {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: 820px;
    }

    .flow-list,
    .card-grid,
    .gallery,
    .faq-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .page-shell {
      padding: 18px;
    }

    .topbar {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 28px;
    }

    .hero {
      gap: 26px;
      padding-bottom: 46px;
    }

    h1 {
      max-width: none;
    }

    .card-grid,
    .flow-list,
    .gallery,
    .faq-list {
      grid-template-columns: 1fr;
    }

    .stat-card {
      position: static;
      max-width: none;
      margin-top: 14px;
    }

    .hero-visual {
      padding-bottom: 0;
    }

    .story-panel,
    .cta-panel,
    .info-card,
    .flow-item,
    .faq-item {
      padding: 22px;
    }
  }
</style>
